# Leave empty to use local Ollama via docker-compose
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional direct OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# LLM models used by the bot
SUPPORT_BOT_CLASSIFIER_MODEL=llama3.2:1b
SUPPORT_BOT_DEDUP_MODEL=llama3.2:1b

# Optional dedup refinement
SUPPORT_BOT_ENABLE_LLM_DEDUP=1

# Runtime paths inside container / local project
SUPPORT_BOT_KB_DIR=./kb
SUPPORT_BOT_ISSUES_PATH=./issues.json
SUPPORT_BOT_TAXONOMY_PATH=./data/taxonomy.json
